{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus"
    },
    "appSqlServerName": {
      "value": "<unique-app-sql-server-name>"
    },
    "jobSqlServerName": {
      "value": "<unique-job-sql-server-name>"
    },
    "entraSqlServerName": {
      "value": "<unique-entra-sql-server-name>"
    },
    "entraAdminLogin": {
      "value": "<entra-admin-display-name>"
    },
    "entraAdminObjectId": {
      "value": "<entra-admin-object-id-guid>"
    },
    "entraTenantId": {
      "value": "<entra-tenant-id-guid>"
    },
    "sqlDatabaseName": {
      "value": "appdb"
    },
    "sqlDatabaseSkuName": {
      "value": "S0"
    },
    "sqlDatabaseSkuTier": {
      "value": "Standard"
    },
    "jobDatabaseName": {
      "value": "jobdb"
    },
    "jobDatabaseSkuName": {
      "value": "S1"
    },
    "jobDatabaseSkuTier": {
      "value": "Standard"
    },
    "elasticJobAgentName": {
      "value": "elastic-job-agent"
    },
    "allowAzureServices": {
      "value": true
    },
    "customFirewallStartIp": {
      "value": ""
    },
    "customFirewallEndIp": {
      "value": ""
    }
  }
}
